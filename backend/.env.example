SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.up.railway.app,.onrender.com

# Database (local)
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=socialapp_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS (comma-separated origins, no trailing slashes)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Throttling (optional — overrides defaults)
THROTTLE_ANON_RATE=100/min
THROTTLE_USER_RATE=300/min
THROTTLE_LOGIN_RATE=5/min
THROTTLE_REGISTER_RATE=3/hour
THROTTLE_POST_CREATE_RATE=20/min
THROTTLE_POST_MUTATE_RATE=30/min
THROTTLE_COMMENT_CREATE_RATE=30/min
THROTTLE_COMMENT_MUTATE_RATE=30/min
THROTTLE_REPLY_CREATE_RATE=30/min
THROTTLE_REPLY_MUTATE_RATE=30/min
THROTTLE_LIKE_RATE=60/min
